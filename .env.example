# ─────────────────────────────────────────────────────────────
# THE BASE — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in every value.
# .env.local is gitignored — never commit it.
#
# This file is optimized for full AI/CLI control:
# every credential here gives the agent or developer
# complete programmatic access — no browser login needed.
# ─────────────────────────────────────────────────────────────


# ── APP ───────────────────────────────────────────────────────
# Public URL of the deployed app (used in email redirects, OG tags, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Display name shown in the UI
NEXT_PUBLIC_APP_NAME=The Base


# ── SUPABASE — Public (safe for browser) ──────────────────────
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Project Settings → API → anon (public) key
# Safe to expose in the browser — restricted by Row Level Security
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...


# ── SUPABASE — Admin (server-side only, never expose to browser) ──
# Project Settings → API → service_role key
# Bypasses ALL Row Level Security — full DB read/write
# Use in: Server Actions, API routes, CLI scripts, migrations
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Project Settings → General → Reference ID (e.g. abcdefghijklmnop)
SUPABASE_PROJECT_REF=your-project-ref

# Organization ID (visible in Supabase dashboard URL: app.supabase.com/org/XXXX)
SUPABASE_ORG_ID=your-org-id

# Database password set during project creation
SUPABASE_DB_PASSWORD=your-db-password

# Direct Postgres connection string — for CLI tools, migrations, ORMs
# Format: postgresql://postgres:[DB_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# Supabase Management API Personal Access Token
# Create at: app.supabase.com/account/tokens
# Scope: full account access — create/delete projects, manage settings, run migrations via API
# Used by: Supabase CLI (supabase login), management API calls, agentic tooling
SUPABASE_ACCESS_TOKEN=sbp_...


# ── VERCEL — Full API Access ───────────────────────────────────
# Create at: vercel.com/account/tokens
# Scope: full account — deploy, manage env vars, domains, project settings
# Used by: Vercel CLI, deployment scripts, agentic deploy automation
VERCEL_TOKEN=vcp_...

# Team ID (visible in Vercel team settings or API responses)
VERCEL_TEAM_ID=team_...

# Project ID (from: vercel.com/[team]/[project]/settings)
VERCEL_PROJECT_ID=prj_...

# CLI alias for team (same as VERCEL_TEAM_ID — used by `vercel` CLI)
VERCEL_ORG_ID=team_...


# ── GITHUB — Full PAT ─────────────────────────────────────────
# Create at: github.com/settings/tokens
# Required scopes: repo (all), workflow, write:packages, admin:org (if needed)
# Used by: git push, PR creation, issue management, GitHub Actions, agentic git ops
GITHUB_TOKEN=ghp_...

# GitHub username or org that owns the repo
GITHUB_OWNER=your-username

# Repository name (without owner prefix)
GITHUB_REPO=the-base

# Full repo URL (used by scripts for clone, remote operations)
GITHUB_REPO_URL=https://github.com/your-username/the-base


# ── ANTHROPIC ─────────────────────────────────────────────────
# Create at: console.anthropic.com/account/keys
# Used by: npm run summarize, any in-app AI features, agentic scripts
ANTHROPIC_API_KEY=sk-ant-...
