# ─────────────────────────────────────────────────────────────
# THE BASE — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy to .env.local and fill in every value.
# .env.local is gitignored — never commit it.
#
# Optimized for full AI/CLI control: every credential here
# gives the agent or developer complete programmatic access.
# Integrations activate automatically when their key is set.
# ─────────────────────────────────────────────────────────────


# ── APP ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=The Base


# ── SUPABASE — Public (browser-safe) ──────────────────────────
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-ref.supabase.co

# Project Settings → API → anon key (restricted by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...


# ── SUPABASE — Admin (server-side only) ───────────────────────
# Project Settings → API → service_role key (bypasses ALL RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Project reference ID (visible in dashboard URL)
SUPABASE_PROJECT_REF=your-project-ref

# Organization ID (app.supabase.com/org/ID)
SUPABASE_ORG_ID=your-org-id

# Database password (set on project creation)
SUPABASE_DB_PASSWORD=your-db-password

# Direct Postgres URL — for CLI, ORMs, migrations
DATABASE_URL=postgresql://postgres:your-password@db.your-ref.supabase.co:5432/postgres

# Management API PAT — create at app.supabase.com/account/tokens
# Full account access: create/delete projects, run migrations via API
# Used by: supabase CLI, bootstrap script, agentic tooling
SUPABASE_ACCESS_TOKEN=sbp_...


# ── VERCEL ────────────────────────────────────────────────────
# Full token — vercel.com/account/tokens
VERCEL_TOKEN=vcp_...

# Team ID — vercel.com/[team]/settings
VERCEL_TEAM_ID=team_...

# Project ID — vercel.com/[team]/[project]/settings
VERCEL_PROJECT_ID=prj_...

# CLI alias (same as team ID)
VERCEL_ORG_ID=team_...


# ── GITHUB ────────────────────────────────────────────────────
# Full PAT — github.com/settings/tokens
# Required scopes: repo (all), workflow, delete_repo
GITHUB_TOKEN=ghp_...

GITHUB_OWNER=your-username
GITHUB_REPO=the-base
GITHUB_REPO_URL=https://github.com/your-username/the-base


# ── ANTHROPIC ─────────────────────────────────────────────────
# console.anthropic.com/account/keys
# Used by: npm run summarize, in-app AI features
ANTHROPIC_API_KEY=sk-ant-...


# ── EMAIL — Resend (activates when set) ───────────────────────
# resend.com/api-keys
# When set: sendEmail(), sendWelcomeEmail(), sendPasswordResetEmail() work
# When not set: logs to console in dev, no-ops in prod
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@yourdomain.com


# ── BILLING — Stripe (activates when set) ─────────────────────
# dashboard.stripe.com/apikeys
# When set: /api/stripe/checkout and /api/stripe/webhook are active
# When not set: billing routes return 503
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret — stripe.com/webhooks (add /api/stripe/webhook endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# Default subscription price ID
STRIPE_PRICE_ID=price_...


# ── ERROR TRACKING — Sentry (activates when set) ───────────────
# sentry.io → Settings → Projects → Client Keys
# When set: errors reported to Sentry dashboard
# When not set: errors logged to console
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org
SENTRY_PROJECT=the-base


# ── OAUTH — via Supabase Auth Providers (activates when set) ───
# Enable providers in: Supabase Dashboard → Auth → Providers
# Then set NEXT_PUBLIC_*_OAUTH_ENABLED=true to show buttons in UI
# Add client ID/secret in Supabase dashboard (not in this file)
NEXT_PUBLIC_GITHUB_OAUTH_ENABLED=false
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false


# ── RATE LIMITING — Upstash Redis (activates when set) ─────────
# upstash.com → Create Database → REST API
# When set: uses Redis for distributed rate limiting (multi-instance prod)
# When not set: uses in-memory Map (fine for dev, single-instance)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
